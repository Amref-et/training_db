APP_NAME="Amref Training Database"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Use your real production URL.
# If clean URLs are fully supported, prefer:
# APP_URL=https://training.example.org
# If the app is hosted in a subdirectory and relies on the front controller fallback, use:
# APP_URL=https://example.org/hil-v2/index.php
APP_URL=https://training.example.org

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=amref_training_db
DB_USERNAME=amref_training_user
DB_PASSWORD=change-this-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# Keep both keys so the app works cleanly across existing config expectations.
CACHE_STORE=file
CACHE_DRIVER=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.org
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.org
MAIL_PASSWORD=change-this-mail-password
MAIL_FROM_ADDRESS=no-reply@example.org
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
