DirectorySlash Off

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /test/hil-v2/pages/

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^$ /test/hil-v2/index.php/pages [L,QSA]
    RewriteRule ^(.*)$ /test/hil-v2/index.php/pages/$1 [L,QSA]
</IfModule>
